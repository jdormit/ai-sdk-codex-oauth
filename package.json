{
  "name": "ai-sdk-codex-oauth",
  "version": "1.1.0",
  "description": "Vercel AI SDK provider for ChatGPT Codex backend via OAuth device code flow",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "import": "./dist/oauth/index.js",
      "require": "./dist/oauth/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.4"
  },
  "keywords": [
    "ai-sdk",
    "openai",
    "codex",
    "oauth",
    "chatgpt",
    "provider",
    "device-code-flow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdormit/ai-sdk-codex-oauth.git"
  },
  "homepage": "https://github.com/jdormit/ai-sdk-codex-oauth#readme",
  "bugs": {
    "url": "https://github.com/jdormit/ai-sdk-codex-oauth/issues"
  }
}
