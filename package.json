{
  "name": "ai-sdk-codex-oauth",
  "version": "0.1.1",
  "description": "Vercel AI SDK provider for ChatGPT Codex backend via OAuth device code flow",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "import": "./dist/oauth/index.js",
      "require": "./dist/oauth/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22"
  },
  "peerDependencies": {
    "ai": ">=4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^1.1.3",
    "@types/node": "^22.0.0",
    "ai": "^4.3.16",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.4"
  },
  "keywords": [
    "ai-sdk",
    "openai",
    "codex",
    "oauth",
    "chatgpt",
    "provider",
    "device-code-flow"
  ],
  "license": "MIT"
}
